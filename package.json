{
  "name": "action-cloudflare-cache",
  "version": "3.0.0",
  "private": false,
  "description": "GitHub Action to purge Cloudflare cache for given URLs",
  "main": "lib/main.js",
  "scripts": {
    "build": "tsc && ncc build",
    "format": "prettier --write **/*.ts",
    "format:check": "prettier --check **/*.ts",
    "lint": "eslint src/**/*.ts",
    "test": "jest --coverage",
    "all": "pnpm format:check && pnpm lint && pnpm test"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/Cyb3r-Jak3/action-cloudflare-cache.git"
  },
  "keywords": [
    "actions",
    "node",
    "cloudflare"
  ],
  "author": {
    "name": "cyb3rjak3",
    "email": "cyb3rjak3@pm.me",
    "url": "https://cyberjake.xyz"
  },
  "license": "MIT",
  "dependencies": {
    "@actions/core": "^1.11.1",
    "axios": "^1.15.0"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3.3.3",
    "@eslint/js": "^9.39.1",
    "@types/jest": "^30.0.0",
    "@types/node": "^20.19.25",
    "@typescript-eslint/eslint-plugin": "^8.48.1",
    "@typescript-eslint/type-utils": "^8.48.1",
    "@typescript-eslint/utils": "^8.48.1",
    "@typescript-eslint/parser": "^8.48.1",
    "@vercel/ncc": "^0.38.4",
    "eslint": "^9.39.1",
    "eslint-plugin-github": "^6.0.0",
    "eslint-plugin-jest": "^28.14.0",
    "eslint-plugin-prettier": "^5.5.4",
    "globals": "^16.5.0",
    "jest": "^30.0.0",
    "jest-circus": "^30.0.0",
    "js-yaml": "^4.1.1",
    "prettier": "3.3.2",
    "ts-jest": "^29.4.6",
    "typescript": "^5.9.3"
  }
}
